# HAchillesWorld 환경변수 예시
# 이 파일을 .env 로 복사한 후 실제 값을 입력하세요
# .env 파일은 절대 Git에 커밋하지 마세요

# HAchillesWorld API (선택 — 로컬 실행 시 불필요)
HACHILLESWORLD_API_KEY=haw-your-key-here

# Anthropic API (내부 AI 분석용, 선택)
HACHILLESWORLD_ANTHROPIC_API_KEY=sk-ant-your-key-here

# 월 예산 상한 (USD, 0 = 무제한)
HACHILLESWORLD_MONTHLY_BUDGET_USD=0.0

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
HACHILLESWORLD_LOG_LEVEL=INFO

# 개발 모드
HACHILLESWORLD_DEBUG=false
